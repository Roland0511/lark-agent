AGENT_DOMAIN=agent.example.internal
AGENT_DISPLAY_NAME=Lark Agent
POSTGRES_PASSWORD=replace-with-random-password
SESSION_SIGNING_SECRET=replace-with-at-least-32-random-characters
# 支持部署在 HTTPS 子路径，例如 https://agent.example.internal/lark-agent。
ADMIN_ORIGIN=https://agent.example.internal/lark-agent
ADMIN_SESSION_HOURS=12
ADMIN_IDLE_MINUTES=120
METRICS_BEARER_TOKEN=replace-with-random-metrics-token
ALERTS_ENABLED=true
LARK_ENABLED=false
# 启用 Agent 回复前，请在飞书开发者后台开通并发布 cardkit:card:write（创建与更新卡片）。
LARK_CARD_ACTIONS_ENABLED=false
MESSAGE_RETENTION_DAYS=30
ATTACHMENT_MAX_BYTES=104857600
ATTACHMENT_TASK_MAX_BYTES=209715200
ATTACHMENT_RETENTION_DAYS=7
# 仅用于 task_events、action_receipts 等技术链路记录，不包含管理操作审计。
TRACE_RETENTION_DAYS=180

# 以下四项只用于空数据库首次引导第一个机器人。导入成功后机器人、主人和群绑定以数据库及 lark-cli profile 为准，长期运行可从私有 .env 删除。
OWNER_OPEN_ID=ou_xxx
BOT_APP_ID=cli_xxx
# 仅由 scripts/init-lark-cli-volume.mjs 读取；初始化成功后应从私有 .env 删除。
BOT_APP_SECRET=replace-with-app-secret
WHITELIST_CHAT_IDS=oc_xxx,oc_yyy

# Runner 安装产物由发布机通过 rsync 同步至 NAS；control 只读取内网 CDN manifest。
RUNNER_ARTIFACT_PUBLIC_BASE_URL=https://cdn.example.com/lark-agent
RUNNER_MANIFEST_REFRESH_SECONDS=300
# 机器人 SkillHub 技能由控制面统一解析和缓存；Token 只进入 control，不下发给 Runner。
SKILLHUB_REGISTRY_URL=https://skillhub.example.internal
SKILLHUB_API_TOKEN=replace-with-skillhub-token
# 运行依赖使用 AES-256-GCM 加密。格式为 keyId:base64-32-byte-key，多把密钥用逗号分隔；
# 轮换时先追加新 key，再切换 active key；系统不会自动重加密历史修订，只有确认引用旧 key 的修订
# 已通过覆盖或删除全部淘汰后，才能移除旧 key。
SKILL_RUNTIME_ENCRYPTION_KEYS=v1:replace-with-base64-32-byte-key
SKILL_RUNTIME_ACTIVE_KEY_ID=v1
# 以下三个变量只用于 pnpm publish:runner，不传入长期运行的 control 容器。密码文件建议放在已忽略的 .private/ 下。
RUNNER_ARTIFACT_RSYNC_TARGET=deploy@example-nas::cdn/lark-agent/
RUNNER_ARTIFACT_RSYNC_PASSWORD_FILE=.private/rsync.pass
RUNNER_NODE_VERSION=24.1.0

# 无反向代理的宿主机部署可配合 compose.host.yaml 使用。
CONTROL_BIND_ADDRESS=127.0.0.1
CONTROL_PORT=3000
