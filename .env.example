AGENT_DOMAIN=agent.example.internal
AGENT_DISPLAY_NAME=Lark Agent
POSTGRES_PASSWORD=replace-with-random-password
SESSION_SIGNING_SECRET=replace-with-at-least-32-random-characters
OWNER_OPEN_ID=ou_xxx
BOT_APP_ID=cli_xxx
# 仅用于 scripts/init-lark-cli-volume.mjs 初始化独立 Docker volume；lark-cli 通过 file 引用读取 0600 文件。
BOT_APP_SECRET=replace-with-app-secret
ADMIN_ORIGIN=https://agent.example.internal
ADMIN_SESSION_HOURS=12
ADMIN_IDLE_MINUTES=120
METRICS_BEARER_TOKEN=replace-with-random-metrics-token
ALERTS_ENABLED=true
WHITELIST_CHAT_IDS=oc_xxx,oc_yyy
LARK_ENABLED=false
# 启用 Agent 回复前，请在飞书开发者后台开通并发布 cardkit:card:write（创建与更新卡片）。
LARK_CARD_ACTIONS_ENABLED=false
MESSAGE_RETENTION_DAYS=30
# 仅用于 task_events、action_receipts 等技术链路记录，不包含管理操作审计。
TRACE_RETENTION_DAYS=180
# Runner 安装产物由发布机通过 rsync 同步至 NAS；control 只读取内网 CDN manifest。
RUNNER_ARTIFACT_PUBLIC_BASE_URL=https://cdn.example.com/lark-agent
RUNNER_MANIFEST_REFRESH_SECONDS=300
# 以下两个变量只用于 pnpm publish:runner，不传入长期运行的 control 容器。
RUNNER_ARTIFACT_RSYNC_TARGET=deploy@example-nas::cdn/lark-agent/
RUNNER_ARTIFACT_RSYNC_PASSWORD_FILE=/secure/path/to/.rsync.pass
RUNNER_NODE_VERSION=24.1.0

# 无反向代理的宿主机部署可配合 compose.host.yaml 使用。
CONTROL_BIND_ADDRESS=127.0.0.1
CONTROL_PORT=3000
