<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.github.lark-agent.worker</string>
  <key>ProgramArguments</key>
  <array>
    <string>/absolute/path/to/lark-agent/scripts/run-worker.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/absolute/path/to/lark-agent</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>WORKER_CONFIG_FILE</key>
    <string>/absolute/path/to/lark-agent/config/worker.local.yaml</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/lark-agent-worker.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/lark-agent-worker.err.log</string>
</dict>
</plist>
